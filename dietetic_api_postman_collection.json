{
  "info": {
    "_postman_id": "6456290d-be06-41ed-bda2-7ad120722e11",
    "name": "Dietetic API - Consulta Dietética",
    "description": "Colección completa para importar en Postman y probar los endpoints del backend de la aplicación de Consultas Dietéticas.\n\n### Configuración de Autenticación:\nLa colección utiliza autenticación heredada a nivel de colección (`Bearer {{token}}`). Las variables de colección `token` y `refresh_token` se actualizan automáticamente al registrarse o iniciar sesión mediante un script de prueba (`Post-response script`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "45096526",
    "_collection_link": "https://go.postman.co/collection/45096526-6456290d-be06-41ed-bda2-7ad120722e11?source=collection_link"
  },
  "item": [
    {
      "name": "01. Autenticación y Usuarios",
      "item": [
        {
          "name": "Registrar Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access);",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nutri_ana\",\n  \"email\": \"ana.gomez@dietetic.com\",\n  \"password\": \"Segura123.\",\n  \"password2\": \"Segura123.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register",
                ""
              ]
            },
            "description": "Registra un nuevo usuario en la plataforma y devuelve el token de acceso inicial."
          },
          "response": []
        },
        {
          "name": "Iniciar Sesión (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.environment.set(\"token\", jsonData.access);",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.environment.set(\"refresh_token\", jsonData.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nutri_ana\",\n  \"password\": \"Segura123.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login",
                ""
              ]
            },
            "description": "Autentica al usuario y guarda el token JWT en las variables de la colección."
          },
          "response": []
        },
        {
          "name": "Refrescar Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "token",
                "refresh",
                ""
              ]
            },
            "description": "Genera un nuevo token de acceso a partir de un token de refresco válido."
          },
          "response": []
        },
        {
          "name": "Verificar Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/verify/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "token",
                "verify",
                ""
              ]
            },
            "description": "Verifica si el token actual de acceso sigue siendo válido."
          },
          "response": []
